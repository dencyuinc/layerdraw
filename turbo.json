{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:types": {
      "dependsOn": ["^build:types"],
      "outputs": ["dist/**/*.d.ts", "dist/**/*.js"]
    },
    "generate": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build:types", "^lint"]
    },
    "test": {
      "dependsOn": ["build", "^test"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^build:types", "^typecheck"]
    }
  }
}

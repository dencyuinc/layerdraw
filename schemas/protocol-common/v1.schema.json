{
  "$schema": "https://schemas.layerdraw.dev/meta/protocol/v1",
  "$id": "https://schemas.layerdraw.dev/protocol-common/v1",
  "$comment": "SPDX-License-Identifier: Apache-2.0",
  "title": "LayerDraw Protocol Common v1",
  "x-layerdraw-go-package": "protocolcommon",
  "x-layerdraw-ts-module": "common",
  "x-layerdraw-max-json-bytes": 8388608,
  "x-layerdraw-max-json-depth": 128,
  "$defs": {
    "BlobLifetime": {
      "type": "string",
      "enum": ["persistent", "request", "session"],
      "description": "The maximum lifetime for which a blob reference remains valid."
    },
    "BlobRef": {
      "type": "object",
      "description": "A transport-neutral reference to bytes transferred outside a JSON control envelope.",
      "properties": {
        "blob_id": {"type": "string", "minLength": 1},
        "digest": {"$ref": "#/$defs/Digest"},
        "lifetime": {"$ref": "#/$defs/BlobLifetime"},
        "media_type": {"type": "string", "minLength": 1},
        "size": {"$ref": "#/$defs/CanonicalUint64"}
      },
      "required": ["blob_id", "digest", "lifetime", "media_type", "size"],
      "additionalProperties": false
    },
    "CanonicalInt64": {
      "type": "string",
      "format": "int64-decimal",
      "pattern": "^(0|-[1-9][0-9]*|[1-9][0-9]*)$",
      "description": "A signed 64-bit integer serialized as a canonical decimal string."
    },
    "CanonicalPositiveInt64": {
      "type": "string",
      "format": "positive-int64-decimal",
      "pattern": "^[1-9][0-9]*$",
      "description": "A positive signed 64-bit quantity serialized as canonical decimal."
    },
    "CanonicalSafeInteger": {
      "type": "string",
      "format": "safe-integer-decimal",
      "pattern": "^(0|-[1-9][0-9]*|[1-9][0-9]*)$",
      "description": "A Language 1 integer in [-9007199254740991, 9007199254740991], serialized as canonical decimal."
    },
    "CanonicalPositiveSafeInteger": {
      "type": "string",
      "format": "positive-safe-integer-decimal",
      "pattern": "^[1-9][0-9]*$",
      "description": "A positive Language 1 integer no greater than 9007199254740991."
    },
    "CanonicalNonNegativeSafeInteger": {
      "type": "string",
      "format": "nonnegative-safe-integer-decimal",
      "pattern": "^(0|[1-9][0-9]*)$",
      "description": "A non-negative Language 1 integer no greater than 9007199254740991."
    },
    "CanonicalNonNegativeInt64": {
      "type": "string",
      "format": "nonnegative-int64-decimal",
      "pattern": "^(0|[1-9][0-9]*)$",
      "description": "A non-negative signed 64-bit compiler-domain quantity serialized as canonical decimal."
    },
    "CanonicalUint64": {
      "type": "string",
      "format": "uint64-decimal",
      "pattern": "^(0|[1-9][0-9]*)$",
      "description": "An unsigned 64-bit integer serialized as a canonical decimal string."
    },
    "CapabilityID": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(?:[.:][a-z][a-z0-9_]*)+$",
      "description": "A typed capability identifier with dot- or colon-separated lowercase namespace segments. Unknown canonical IDs remain representable."
    },
    "ByteResourceLimitCapability": {
      "type": "object",
      "description": "Endpoint default, hard ceiling, and negotiated effective byte ceiling.",
      "properties": {
        "default_value": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "effective_maximum": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "hard_maximum": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "unit": {"type": "string", "const": "bytes"}
      },
      "required": ["unit", "default_value", "hard_maximum", "effective_maximum"],
      "additionalProperties": false,
      "x-layerdraw-limit-capability": true
    },
    "ItemResourceLimitCapability": {
      "type": "object",
      "description": "Endpoint default, hard ceiling, and negotiated effective item ceiling.",
      "properties": {
        "default_value": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "effective_maximum": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "hard_maximum": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "unit": {"type": "string", "const": "items"}
      },
      "required": ["unit", "default_value", "hard_maximum", "effective_maximum"],
      "additionalProperties": false,
      "x-layerdraw-limit-capability": true
    },
    "RasterDimensionResourceLimitCapability": {
      "type": "object",
      "description": "Endpoint default, hard ceiling, and negotiated effective pixels-per-axis ceiling.",
      "properties": {
        "default_value": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "effective_maximum": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "hard_maximum": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "unit": {"type": "string", "const": "pixels_per_axis"}
      },
      "required": ["unit", "default_value", "hard_maximum", "effective_maximum"],
      "additionalProperties": false,
      "x-layerdraw-limit-capability": true
    },
    "RasterPixelResourceLimitCapability": {
      "type": "object",
      "description": "Endpoint default, hard ceiling, and negotiated effective raster-pixel ceiling.",
      "properties": {
        "default_value": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "effective_maximum": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "hard_maximum": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "unit": {"type": "string", "const": "pixels"}
      },
      "required": ["unit", "default_value", "hard_maximum", "effective_maximum"],
      "additionalProperties": false,
      "x-layerdraw-limit-capability": true
    },
    "CompileResourceLimitConstraints": {
      "type": "object",
      "description": "Optional positive client ceilings. Omission means the client imposes no ceiling for that key; zero is not a client-ceiling sentinel.",
      "properties": {
        "max_asset_bytes": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "max_assets": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "max_declarations": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "max_pack_bytes": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "max_pack_files": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "max_project_source_bytes": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "max_project_source_files": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "max_raster_dimension": {"$ref": "#/$defs/CanonicalPositiveInt64"},
        "max_raster_pixels": {"$ref": "#/$defs/CanonicalPositiveInt64"}
      },
      "additionalProperties": false
    },
    "CompileResourceLimitCapabilities": {
      "type": "object",
      "description": "The closed Engine 1.0 compile-limit catalog. Each key fixes its unit and separates endpoint default, endpoint hard maximum, and negotiated effective maximum.",
      "properties": {
        "max_asset_bytes": {"$ref": "#/$defs/ByteResourceLimitCapability"},
        "max_assets": {"$ref": "#/$defs/ItemResourceLimitCapability"},
        "max_declarations": {"$ref": "#/$defs/ItemResourceLimitCapability"},
        "max_pack_bytes": {"$ref": "#/$defs/ByteResourceLimitCapability"},
        "max_pack_files": {"$ref": "#/$defs/ItemResourceLimitCapability"},
        "max_project_source_bytes": {"$ref": "#/$defs/ByteResourceLimitCapability"},
        "max_project_source_files": {"$ref": "#/$defs/ItemResourceLimitCapability"},
        "max_raster_dimension": {"$ref": "#/$defs/RasterDimensionResourceLimitCapability"},
        "max_raster_pixels": {"$ref": "#/$defs/RasterPixelResourceLimitCapability"}
      },
      "required": ["max_asset_bytes", "max_assets", "max_declarations", "max_pack_bytes", "max_pack_files", "max_project_source_bytes", "max_project_source_files", "max_raster_dimension", "max_raster_pixels"],
      "additionalProperties": false
    },
    "CapabilityManifest": {
      "type": "object",
      "description": "The capabilities this endpoint can actually execute for the negotiated scope.",
      "properties": {
        "actor_scope_digest": {"$ref": "#/$defs/Digest"},
        "authoring_grant_summary": {"$ref": "#/$defs/JsonObject"},
        "embedding_profiles": {"type": "array", "items": {"$ref": "#/$defs/ProfileCapability"}},
        "exporter_profiles": {"type": "array", "items": {"$ref": "#/$defs/ProfileCapability"}},
        "extensions": {"$ref": "#/$defs/Extensions"},
        "limits": {"$ref": "#/$defs/CompileResourceLimitCapabilities"},
        "manifest_etag": {"$ref": "#/$defs/ManifestETag"},
        "manifest_scope": {"$ref": "#/$defs/ManifestScope"},
        "manifest_version": {"type": "integer", "minimum": 1, "maximum": 2147483647},
        "operations": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/OperationCapability"}
        },
        "query_adapters": {"type": "array", "items": {"$ref": "#/$defs/ProfileCapability"}},
        "realtime_profiles": {"type": "array", "items": {"$ref": "#/$defs/ProfileCapability"}},
        "registry_sources": {"type": "array", "items": {"$ref": "#/$defs/ProfileCapability"}},
        "renderer_profiles": {"type": "array", "items": {"$ref": "#/$defs/ProfileCapability"}},
        "required_ladybug_primitives": {"type": "array", "items": {"type": "string"}},
        "search_profiles": {"type": "array", "items": {"$ref": "#/$defs/ProfileCapability"}},
        "storage_capabilities": {"type": "array", "items": {"$ref": "#/$defs/ProfileCapability"}},
        "transports": {"type": "array", "items": {"type": "string"}}
      },
      "required": ["manifest_version", "manifest_etag", "manifest_scope", "operations", "transports", "limits", "query_adapters", "realtime_profiles", "registry_sources", "renderer_profiles", "exporter_profiles", "search_profiles", "embedding_profiles", "required_ladybug_primitives", "storage_capabilities"],
      "additionalProperties": false
    },
    "Digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "description": "A SHA-256 digest with an exact lowercase 64-hex payload."
    },
    "EndpointInstanceID": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "description": "An injected opaque non-secret identifier stable for one endpoint instance. Its construction and lifecycle belong to Issue #28."
    },
    "Extensions": {
      "type": "object",
      "description": "Explicit namespaced compatible-minor extension data. Unknown top-level fields are rejected.",
      "additionalProperties": {"$ref": "#/$defs/JsonValue"}
    },
    "HandshakeRequest": {
      "type": "object",
      "description": "Client protocol ranges, exact schema digests, capability requirements, and limits.",
      "properties": {
        "client_limits": {"$ref": "#/$defs/CompileResourceLimitConstraints"},
        "client_release": {"$ref": "#/$defs/ReleaseVersion"},
        "extensions": {"$ref": "#/$defs/Extensions"},
        "optional_capabilities": {"type": "array", "items": {"$ref": "#/$defs/CapabilityID"}, "uniqueItems": true},
        "protocols": {"type": "array", "items": {"$ref": "#/$defs/ProtocolOffer"}, "minItems": 1},
        "required_capabilities": {"type": "array", "items": {"$ref": "#/$defs/CapabilityID"}, "uniqueItems": true}
      },
      "required": ["client_release", "protocols", "required_capabilities", "optional_capabilities"],
      "additionalProperties": false,
      "x-layerdraw-disjoint-arrays": [
        {"left": "required_capabilities", "right": "optional_capabilities"}
      ],
      "x-layerdraw-unique-array-keys": [
        {"array": "protocols", "property": "name"}
      ]
    },
    "HandshakeResult": {
      "type": "object",
      "description": "The host identity, negotiated versions, effective manifest, and release manifest digest.",
      "properties": {
        "capability_manifest": {"$ref": "#/$defs/CapabilityManifest"},
        "capability_statuses": {"type": "array", "items": {"$ref": "#/$defs/RequestedCapabilityStatus"}},
        "endpoint_instance_id": {"$ref": "#/$defs/EndpointInstanceID"},
        "extensions": {"$ref": "#/$defs/Extensions"},
        "host_release": {"$ref": "#/$defs/ReleaseVersion"},
        "negotiated_protocols": {"type": "array", "items": {"$ref": "#/$defs/NegotiatedProtocol"}},
        "release_manifest_digest": {"$ref": "#/$defs/Digest"}
      },
      "required": ["host_release", "endpoint_instance_id", "negotiated_protocols", "capability_statuses", "capability_manifest", "release_manifest_digest"],
      "additionalProperties": false,
      "x-layerdraw-unique-array-keys": [
        {"array": "capability_statuses", "property": "capability_id"},
        {"array": "negotiated_protocols", "property": "name"}
      ]
    },
    "JsonObject": {
      "type": "object",
      "description": "An explicitly open JSON object used only for safe diagnostic or extension data.",
      "additionalProperties": {"$ref": "#/$defs/JsonValue"}
    },
    "JsonValue": {
      "oneOf": [
        {"type": "null"},
        {"type": "boolean"},
        {"type": "string"},
        {"type": "array", "items": {"$ref": "#/$defs/JsonValue"}},
        {"type": "object", "additionalProperties": {"$ref": "#/$defs/JsonValue"}}
      ],
      "description": "A recursive canonical JSON value excluding numbers so JavaScript precision cannot change diagnostic or extension data."
    },
    "ManifestScope": {
      "type": "string",
      "enum": ["client", "effective", "endpoint"]
    },
    "ManifestETag": {
      "$ref": "#/$defs/Digest",
      "description": "The SHA-256 identity of the canonical effective manifest projection with this field excluded. Construction belongs to Issue #28."
    },
    "ProtocolVersion": {
      "type": "string",
      "format": "protocol-version",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$",
      "description": "A canonical major.minor protocol version whose components are unsigned 32-bit integers."
    },
    "ProtocolVersionRange": {
      "type": "string",
      "format": "protocol-version-range",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$",
      "description": "A closed inclusive lower..upper range within one major. Both bounds are canonical major.minor values and the lower bound must not exceed the upper bound."
    },
    "ProtocolVersionOrRange": {
      "type": "string",
      "format": "protocol-version-or-range",
      "description": "Either one canonical major.minor version or one canonical inclusive lower..upper range."
    },
    "ReleaseVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
      "description": "A canonical SemVer 2.0.0 release identifier."
    },
    "NegotiatedProtocol": {
      "type": "object",
      "properties": {
        "name": {"type": "string", "pattern": "^[a-z][a-z0-9._-]*$"},
        "schema_digest": {"$ref": "#/$defs/Digest"},
        "version": {"$ref": "#/$defs/ProtocolVersion"}
      },
      "required": ["name", "version", "schema_digest"],
      "additionalProperties": false
    },
    "OperationCapability": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "extensions": {"$ref": "#/$defs/Extensions"},
        "limits": {"$ref": "#/$defs/CompileResourceLimitConstraints"},
        "protocol_version": {"$ref": "#/$defs/ProtocolVersion"},
        "required_authoring_capabilities": {"type": "array", "items": {"type": "string"}},
        "unavailable_reason": {"$ref": "#/$defs/UnavailableReason"}
      },
      "required": ["enabled", "protocol_version"],
      "additionalProperties": false,
      "x-layerdraw-tagged-union": {
        "property": "enabled",
        "variants": {
          "false": {"required": ["unavailable_reason"]},
          "true": {"forbidden": ["unavailable_reason"]}
        }
      }
    },
    "Outcome": {
      "type": "string",
      "enum": ["cancelled", "failed", "rejected", "success"]
    },
    "PageInfo": {
      "type": "object",
      "properties": {
        "next_cursor": {"type": "string"},
        "result_truncated": {"type": "boolean"},
        "returned_bytes": {"$ref": "#/$defs/CanonicalUint64"},
        "returned_items": {"$ref": "#/$defs/CanonicalUint64"},
        "total_items": {"$ref": "#/$defs/TotalItems"}
      },
      "required": ["result_truncated", "returned_items", "returned_bytes"],
      "additionalProperties": false
    },
    "ProfileCapability": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "extensions": {"$ref": "#/$defs/Extensions"},
        "id": {"type": "string", "minLength": 1},
        "unavailable_reason": {"$ref": "#/$defs/UnavailableReason"},
        "version": {"type": "string", "minLength": 1}
      },
      "required": ["id", "version", "enabled"],
      "additionalProperties": false,
      "x-layerdraw-tagged-union": {
        "property": "enabled",
        "variants": {
          "false": {"required": ["unavailable_reason"]},
          "true": {"forbidden": ["unavailable_reason"]}
        }
      }
    },
    "ProtocolDiagnostic": {
      "type": "object",
      "description": "A non-LDL protocol, compatibility, policy, or operation diagnostic. LDL compiler diagnostics use semantic.Diagnostic instead.",
      "properties": {
        "code": {"type": "string", "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$"},
        "data": {"$ref": "#/$defs/JsonObject"},
        "message": {"type": "string"},
        "related": {"type": "array", "items": {"$ref": "#/$defs/ProtocolDiagnosticRelated"}},
        "remediation": {"type": "string"},
        "severity": {"$ref": "#/$defs/ProtocolDiagnosticSeverity"},
        "source": {"$ref": "#/$defs/ProtocolDiagnosticSource"}
      },
      "required": ["code", "severity", "message", "related"],
      "additionalProperties": false
    },
    "ProtocolDiagnosticRelated": {
      "type": "object",
      "properties": {
        "message": {"type": "string"},
        "relation": {"type": "string", "minLength": 1},
        "source": {"$ref": "#/$defs/ProtocolDiagnosticSource"}
      },
      "required": ["relation", "message"],
      "additionalProperties": false
    },
    "ProtocolDiagnosticSeverity": {
      "type": "string",
      "enum": ["error", "hint", "information", "warning"]
    },
    "ProtocolDiagnosticSource": {
      "type": "object",
      "properties": {
        "module_path": {"type": "string"},
        "span": {"$ref": "#/$defs/ProtocolDiagnosticSpan"},
        "stable_address": {"type": "string"}
      },
      "required": ["module_path", "span"],
      "additionalProperties": false
    },
    "ProtocolDiagnosticSpan": {
      "type": "object",
      "properties": {
        "end_byte": {"$ref": "#/$defs/CanonicalUint64"},
        "start_byte": {"$ref": "#/$defs/CanonicalUint64"}
      },
      "required": ["start_byte", "end_byte"],
      "additionalProperties": false,
      "x-layerdraw-ordered-range": true
    },
    "ProtocolFailure": {
      "type": "object",
      "description": "A safe transport or execution-platform failure, never a source diagnostic.",
      "properties": {
        "category": {"$ref": "#/$defs/ProtocolFailureCategory"},
        "code": {"type": "string", "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$"},
        "correlation_id": {"type": "string"},
        "extensions": {"$ref": "#/$defs/Extensions"},
        "message": {"type": "string"},
        "retry_after_ms": {"$ref": "#/$defs/CanonicalUint64"},
        "retryable": {"type": "boolean"},
        "safe_details": {"$ref": "#/$defs/JsonObject"}
      },
      "required": ["code", "category", "message", "retryable"],
      "additionalProperties": false
    },
    "ProtocolFailureCategory": {
      "type": "string",
      "enum": ["adapter", "cancelled", "invariant", "io", "resource", "transport"]
    },
    "ProtocolOffer": {
      "type": "object",
      "properties": {
        "name": {"type": "string", "pattern": "^[a-z][a-z0-9._-]*$"},
        "supported_range": {"$ref": "#/$defs/ProtocolVersionRange"},
        "versions": {"type": "array", "items": {"$ref": "#/$defs/ProtocolVersionBinding"}, "minItems": 1}
      },
      "required": ["name", "supported_range", "versions"],
      "additionalProperties": false,
      "x-layerdraw-protocol-offer": true
    },
    "ProtocolVersionBinding": {
      "type": "object",
      "description": "The exact schema digest associated with one offered protocol version.",
      "properties": {
        "schema_digest": {"$ref": "#/$defs/Digest"},
        "version": {"$ref": "#/$defs/ProtocolVersion"}
      },
      "required": ["version", "schema_digest"],
      "additionalProperties": false
    },
    "ProtocolRef": {
      "type": "object",
      "properties": {
        "name": {"type": "string", "pattern": "^[a-z][a-z0-9._-]*$"},
        "version": {"$ref": "#/$defs/ProtocolVersion"}
      },
      "required": ["name", "version"],
      "additionalProperties": false
    },
    "RequestMetadata": {
      "type": "object",
      "description": "The common top-level metadata copied into every operation request envelope.",
      "properties": {
        "deadline_at": {"$ref": "#/$defs/Rfc3339Time"},
        "extensions": {"$ref": "#/$defs/Extensions"},
        "operation": {"type": "string", "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"},
        "protocol": {"$ref": "#/$defs/ProtocolRef"},
        "request_id": {"type": "string", "minLength": 1},
        "trace_context": {"$ref": "#/$defs/JsonObject"}
      },
      "required": ["protocol", "request_id", "operation"],
      "additionalProperties": false
    },
    "ResponseMetadata": {
      "type": "object",
      "description": "The common top-level metadata copied into every operation response envelope.",
      "properties": {
        "engine_release": {"$ref": "#/$defs/ReleaseVersion"},
        "extensions": {"$ref": "#/$defs/Extensions"},
        "host_release": {"$ref": "#/$defs/ReleaseVersion"},
        "outcome": {"$ref": "#/$defs/Outcome"},
        "protocol": {"$ref": "#/$defs/ProtocolRef"},
        "request_id": {"type": "string", "minLength": 1}
      },
      "required": ["protocol", "request_id", "outcome"],
      "additionalProperties": false
    },
    "Rfc3339Time": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\\.[0-9]{1,9})?Z$",
      "description": "A real-calendar UTC RFC 3339 timestamp with a required Z suffix and at most nine fractional digits."
    },
    "TotalItems": {
      "type": "object",
      "description": "An explicit unknown or exact item count; omission is never used to imply truncation.",
      "properties": {
        "exact": {"$ref": "#/$defs/CanonicalUint64"},
        "known": {"type": "boolean"}
      },
      "required": ["known"],
      "additionalProperties": false,
      "x-layerdraw-tagged-union": {
        "property": "known",
        "variants": {
          "false": {"forbidden": ["exact"]},
          "true": {"required": ["exact"]}
        }
      }
    },
    "UnavailableReason": {
      "type": "string",
      "enum": ["degraded", "incompatible", "not_authorized", "not_configured", "not_entitled", "not_linked", "offline", "unsupported"]
    },
    "RequestedCapabilityStatus": {
      "type": "object",
      "description": "An explicit result for every requested capability ID, including unknown optional IDs.",
      "properties": {
        "capability_id": {"$ref": "#/$defs/CapabilityID"},
        "enabled": {"type": "boolean"},
        "protocol_version": {"$ref": "#/$defs/ProtocolVersion"},
        "unavailable_reason": {"$ref": "#/$defs/UnavailableReason"}
      },
      "required": ["capability_id", "enabled", "protocol_version"],
      "additionalProperties": false,
      "x-layerdraw-tagged-union": {
        "property": "enabled",
        "variants": {
          "false": {"required": ["unavailable_reason"]},
          "true": {"forbidden": ["unavailable_reason"]}
        }
      }
    },
    "UpgradeDiagnosticData": {
      "type": "object",
      "description": "The normative Section 10.9 upgrade and compatibility diagnostic data.",
      "properties": {
        "affected_artifacts": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "current_version": {"$ref": "#/$defs/ProtocolVersion"},
        "migration_available": {"type": "boolean"},
        "migration_plan_ref": {"type": "string", "minLength": 1},
        "readonly_possible": {"type": "boolean"},
        "replacement_profile": {"type": "string", "minLength": 1},

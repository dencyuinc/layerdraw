{
  "name": "@layerdraw/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "LayerDraw Desktop Wails frontend composition shell.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "sideEffects": ["./dist/styles.css"],
  "exports": {
    ".": {"types": "./dist/index.d.ts", "import": "./dist/index.js"},
    "./contracts": {"types": "./dist/contracts.d.ts", "import": "./dist/contracts.js"},
    "./controller": {"types": "./dist/controller.d.ts", "import": "./dist/controller.js"},
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "node scripts/normalize-wails-bindings.mjs && node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json && cp src/styles.css dist/styles.css && node scripts/build-frontend.mjs",
    "build:types": "tsc -p tsconfig.build.json && cp src/styles.css dist/styles.css",
    "generate": "node -e \"\"",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --experimental-test-coverage --test-coverage-include=dist/controller.js --test-coverage-lines=85 --test-coverage-functions=85 --test-coverage-branches=80 test/*.test.mjs && node test/browser-e2e.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@layerdraw/client-sdk": "workspace:*",
    "@layerdraw/composer": "workspace:*",
    "@layerdraw/engine-client": "workspace:*",
    "@layerdraw/export": "workspace:*",
    "@layerdraw/library": "workspace:*",
    "@layerdraw/protocol": "workspace:*",
    "@layerdraw/react": "workspace:*",
    "@layerdraw/registry-client": "workspace:*",
    "@layerdraw/render": "workspace:*",
    "@layerdraw/review": "workspace:*",
    "@layerdraw/viewer": "workspace:*",
    "react": ">=19.0.0 <20",
    "react-dom": ">=19.0.0 <20",
    "three": "0.179.1"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@playwright/test": "1.61.1",
    "@types/three": "0.179.0",
    "esbuild-wasm": "0.25.12",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-test-renderer": "19.2.7",
    "@types/react-test-renderer": "19.1.0",
    "typescript": "7.0.2"
  },
  "engines": {"node": ">=24.18.0 <25"}
}

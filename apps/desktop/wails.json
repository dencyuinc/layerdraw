{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "layerdraw-desktop",
  "outputfilename": "LayerDraw",
  "frontend:dir": "frontend",
	"frontend:install": "pnpm install --frozen-lockfile",
	"frontend:build": "pnpm turbo run build --filter @layerdraw/desktop",
	"assetdir": "frontend/dist",
  "info": {
    "companyName": "Dencyu Inc.",
    "productName": "LayerDraw",
    "productVersion": "0.0.0-dev",
    "fileAssociations": [
      {"ext": "ldl", "name": "LayerDraw LDL Project", "description": "LayerDraw project source", "iconName": "appicon", "role": "Editor"},
      {"ext": "layerdraw", "name": "LayerDraw Project", "description": "LayerDraw project container", "iconName": "appicon", "role": "Editor"}
    ]
	}
}

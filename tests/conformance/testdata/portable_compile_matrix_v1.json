{
  "schema_version": 1,
  "corpus": "tests/conformance/testdata/engine_compile_parity_v1.json",
  "required_transports": [
    "in_process_go",
    "packaged_stdio_raw",
    "engine_client_stdio",
    "node_wasm_worker",
    "browser_wasm_worker",
    "engine_client_browser_wasm"
  ],
  "assertions": [
    "normalized_response",
    "outcome",
    "diagnostics",
    "definition_hash",
    "subject_semantic_hashes",
    "stable_addresses",
    "recipes",
    "classifications",
    "output_blob_metadata",
    "canonical_output_bytes"
  ],
  "transports": [
    {
      "id": "in_process_go",
      "case_scope": "all",
      "authority": {
        "path": "tools/wasmparity/main_test.go",
        "test": "TestGeneratedParityCorpusIsCurrentAndDeterministic"
      }
    },
    {
      "id": "packaged_stdio_raw",
      "case_scope": "compile",
      "authority": {
        "path": "tests/packaged/portable_corpus_test.go",
        "test": "TestPackagedStdioExecutesPortableCompilerCorpus"
      }
    },
    {
      "id": "engine_client_stdio",
      "case_scope": "all",
      "authority": {
        "path": "packages/engine-client/test/stdio-adapter.test.mjs",
        "test": "stdio client executes the portable corpus through the real Go sidecar"
      }
    },
    {
      "id": "node_wasm_worker",
      "case_scope": "compile_and_hard_cancel",
      "authority": {
        "path": "packages/engine-wasm/test/node-harness.test.mjs",
        "test": "real Node worker_threads owns the packaged Go/WASM lifecycle"
      }
    },
    {
      "id": "browser_wasm_worker",
      "case_scope": "compile_and_hard_cancel",
      "authority": {
        "path": "packages/engine-wasm/test/browser/engine-worker.spec.ts",
        "test": "packaged module Worker executes the parity corpus through real Go/WASM"
      }
    },
    {
      "id": "engine_client_browser_wasm",
      "case_scope": "all",
      "authority": {
        "path": "packages/engine-wasm/test/browser/engine-worker.spec.ts",
        "test": "public Engine client compiles the parity corpus through a real Go/WASM Worker"
      }
    }
  ],
  "failure_classes": [
    {
      "id": "corrupt",
      "authorities": [
        {
          "path": "packages/engine-client/test/client-contract.test.mjs",
          "test": "output missing, unexpected, corrupt, and role-conflicting tables poison and replace"
        },
        {
          "path": "tools/releaseset/main_test.go",
          "test": "TestVerifyRejectsCorruptStaleAndUnsupportedReleaseState"
        }
      ]
    },
    {
      "id": "mismatched",
      "authorities": [
        {
          "path": "packages/engine-wasm/test/node-harness.test.mjs",
          "test": "Ready is blocked by linked Go release authority after a self-consistent package, manifest, and SBOM forgery"
        },
        {
          "path": "tests/packaged/release_set_test.go",
          "test": "TestFixedReleaseSetNativeUsesVerifiedSidecarIdentity"
        }
      ]
    },
    {
      "id": "stale",
      "authorities": [
        {
          "path": "packages/engine-wasm/test/browser/engine-worker.spec.ts",
          "test": "real Worker rejects stale ownership, cleans up, and surfaces an isolated runtime crash"
        }
      ]
    },
    {
      "id": "truncated",
      "authorities": [
        {
          "path": "internal/transport/stdio/reader_test.go",
          "test": "TestDecoderDistinguishesCleanEOFAndTruncation"
        }
      ]
    },
    {
      "id": "oversized",
      "authorities": [
        {
          "path": "internal/transport/stdio/session_test.go",
          "test": "TestSessionAdmissionLimitAndZeroByteFinal"
        },
        {
          "path": "packages/engine-wasm/test/node-harness.test.mjs",
          "test": "Go bridge rejects an outer attachment size mismatch before attachment acquisition"
        }
      ]
    },
    {
      "id": "unsupported",
      "authorities": [
        {
          "path": "internal/engine/endpoint/endpoint_test.go",
          "test": "TestNegotiateRejections"
        }
      ]
    }
  ]
}

  "scenarios": [
    {
      "name": "source_patch_preview_apply",
      "source": "project p \"Project\" {}\n// keep\n",
      "patch": {
        "module_path": "document.ldl",
        "find": "keep",
        "replace": "kept"
      },
      "expected": {
        "open_state_kind": "project_available",
        "open_semantic_state": "available",
        "initial_generation": "1",
        "preview_status": "valid",
        "changed_source_files": ["document.ldl"],
        "applied_generation": "2",
        "final_contains": "// kept\n",
        "stale_apply_outcome": "rejected",
        "stale_apply_diagnostic_code": "LDL1801",
        "close_outcome": "success"
      }
    }
  ]

{
  "schema_version": 1,
  "corpus": "portable-workbench-editing",
  "required_transports": [
    "in_process_go",
    "packaged_stdio_raw",
    "engine_client_stdio",
    "node_wasm_worker",
    "browser_wasm_worker",
    "engine_client_browser_wasm"
  ],
  "normalization": [
    "endpoint_instance_id, document_handle.value, and preview_id.value are endpoint-local opaque values",

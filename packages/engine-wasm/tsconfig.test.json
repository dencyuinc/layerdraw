{
  "compilerOptions": {
    "exactOptionalPropertyTypes": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": false,
    "strict": true,
    "target": "ES2024",
    "types": ["node", "@playwright/test"]
  },
  "include": ["playwright.config.ts", "test/browser/**/*.ts"]
}

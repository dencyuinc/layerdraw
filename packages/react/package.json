{
  "name": "@layerdraw/react",
  "version": "0.0.0",
  "description": "Accessible React editor and live Viewer foundations over injected LayerDraw facades.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "sideEffects": [
    "./dist/tokens.css",
    "./dist/styles.css"
  ],
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.css",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.js"
    },
    "./controls": {
      "types": "./dist/controls.d.ts",
      "import": "./dist/controls.js"
    },
    "./layout": {
      "types": "./dist/layout.d.ts",
      "import": "./dist/layout.js"
    },
    "./navigation": {
      "types": "./dist/navigation.d.ts",
      "import": "./dist/navigation.js"
    },
    "./query-viewer": {
      "types": "./dist/query-viewer.d.ts",
      "import": "./dist/query-viewer.js"
    },
    "./recovery": {
      "types": "./dist/recovery.d.ts",
      "import": "./dist/recovery.js"
    },
    "./review": {
      "types": "./dist/review.d.ts",
      "import": "./dist/review.js"
    },
    "./i18n": {
      "types": "./dist/i18n.d.ts",
      "import": "./dist/i18n.js"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives/index.js"
    },
    "./primitives.css": "./dist/primitives.css",
    "./tokens.css": "./dist/tokens.css",
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json && cp src/tokens.css dist/tokens.css && cp src/styles.css dist/styles.css && tailwindcss -i src/primitives.css -o dist/primitives.css",
    "build:types": "tsc -p tsconfig.build.json && cp src/tokens.css dist/tokens.css && cp src/styles.css dist/styles.css && tailwindcss -i src/primitives.css -o dist/primitives.css",
    "generate": "node scripts/generate-tokens-css.mjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --experimental-test-coverage --test-coverage-include=dist/**/*.js --test-coverage-lines=75 --test-coverage-functions=75 --test-coverage-branches=70 test/*.test.mjs && node test/browser-e2e.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "@layerdraw/client-sdk": "workspace:*",
    "@layerdraw/composer": "workspace:*",
    "@layerdraw/protocol": "workspace:*",
    "@layerdraw/review": "workspace:*",
    "@layerdraw/viewer": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19.0.0 <20",
    "react-dom": ">=19.0.0 <20"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/cli": "^4.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-test-renderer": "19.1.0",
    "esbuild-wasm": "0.25.12",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-test-renderer": "19.2.7",
    "tailwindcss": "^4.3.3",
    "typescript": "7.0.2"
  },
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}

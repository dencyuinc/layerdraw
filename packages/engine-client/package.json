{
  "name": "@layerdraw/engine-client",
  "version": "0.0.0",
  "description": "Transport-neutral client contract for the LayerDraw Engine.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./stdio": {
      "types": "./dist/stdio.d.ts",
      "import": "./dist/stdio.js"
    },
    "./wasm": {
      "types": "./dist/wasm.d.ts",
      "import": "./dist/wasm.js"
    }
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "generate": "node -e \"\"",
    "lint": "pnpm --filter @layerdraw/protocol build && tsc -p tsconfig.json --noEmit",
    "test": "node --test --experimental-test-coverage --test-coverage-include=dist/**/*.js --test-coverage-exclude=dist/internal/testing.js --test-coverage-lines=85 --test-coverage-functions=85 --test-coverage-branches=80 test/*.test.mjs",
    "typecheck": "pnpm --filter @layerdraw/protocol build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@layerdraw/protocol": "workspace:*"
  },
  "devDependencies": {
    "@layerdraw/engine-wasm": "workspace:*",
    "@types/node": "24.13.3",
    "typescript": "7.0.2"
  },
  "peerDependencies": {
    "@layerdraw/engine-wasm": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@layerdraw/engine-wasm": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
